#!/bin/bash
export PATH="/usr/lib/jvm/java-21-openjdk-amd64/bin:$PATH"

FAILED=0

TEST_LOG="$(mktemp)"
trap 'rm -f "$TEST_LOG"' EXIT

# Run all checks and continue on failure
bun test >"$TEST_LOG" 2>&1 || { tail -n 200 "$TEST_LOG"; FAILED=1; }
bun ./tools/inline-check.ts --git-files-only || FAILED=1
npm run cpd || FAILED=1
bun run format || FAILED=1
bun run lint:fix || FAILED=1
bun run check:circular || FAILED=1
bun run check:structure || FAILED=1
bun run check:subdir-deps || FAILED=1

# Run visualize but don't fail on it
npm run visualize

# Exit with failure if any check failed
if [ $FAILED -eq 1 ]; then
  exit 1
fi