#!/bin/bash
export PATH="/usr/lib/jvm/java-21-openjdk-amd64/bin:$PATH"

FAILED=0

# Helper function to run a gate and print success/failure
run_gate() {
  local gate_name="$1"
  shift
  local output
  output=$("$@" 2>&1)
  local exit_code=$?
  
  if [ $exit_code -eq 0 ]; then
    echo "✓ $gate_name passes!"
  else
    echo "$output"
    FAILED=1
  fi
  
  return $exit_code
}

# Run all checks
run_gate "Tests" bun test
run_gate "Inline check" bun ./tools/inline-check.ts --git-files-only
run_gate "Copy/paste detection" npm run cpd
run_gate "Format" bun run format
run_gate "Lint" bun run lint:fix
run_gate "Circular dependencies" bun run check:circular
run_gate "Directory structure" bun run check:structure
run_gate "Subdirectory dependencies" bun run check:subdir-deps

# Run visualize but don't fail on it
npm run visualize >/dev/null 2>&1

# Exit with failure if any check failed
if [ $FAILED -eq 1 ]; then
  exit 1
fi