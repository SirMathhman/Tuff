// Test: contains method
use string;
use io;

extern fn exit(code: I32): Void;

let s = "hello world";

if (!s.contains("hello")) {
	println("FAIL: contains 'hello'");
	exit(1);
}

if (!s.contains("world")) {
	println("FAIL: contains 'world'");
	exit(2);
}

if (!s.contains("o w")) {
	println("FAIL: contains 'o w'");
	exit(3);
}

if (s.contains("xyz")) {
	println("FAIL: should not contain 'xyz'");
	exit(4);
}

if (!s.contains("")) {
	println("FAIL: should contain empty string");
	exit(5);
}

println("PASS");
0
