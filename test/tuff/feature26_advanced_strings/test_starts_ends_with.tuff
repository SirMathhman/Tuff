// Test: startsWith and endsWith methods
use string;
use io;

extern fn exit(code: I32): Void;

let s = "hello world";

// Test startsWith
if (!s.startsWith("hello")) {
	println("FAIL: startsWith('hello')");
	exit(1);
}

if (s.startsWith("world")) {
	println("FAIL: should not start with 'world'");
	exit(2);
}

if (!s.startsWith("")) {
	println("FAIL: should start with empty string");
	exit(3);
}

// Test endsWith
if (!s.endsWith("world")) {
	println("FAIL: endsWith('world')");
	exit(4);
}

if (s.endsWith("hello")) {
	println("FAIL: should not end with 'hello'");
	exit(5);
}

if (!s.endsWith("")) {
	println("FAIL: should end with empty string");
	exit(6);
}

println("PASS");
0
