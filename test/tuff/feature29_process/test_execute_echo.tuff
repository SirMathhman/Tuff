// Test: Process execution - echo command
// Expected: exit code 0 (echo succeeds)

use io;
use process;
use vector;
use result;

fn main(): I32 => {
	// Create args vector: /c tells cmd to execute the command and exit
	let mut args = Vector::new<string>(4USize);
	args.push("/c");
	args.push("echo");
	args.push("hello");
	args.push("world");
	
	// Execute "cmd /c echo hello world" on Windows
	let result = execute("cmd", &args, "");
	
	if (result is Ok<I32, string>) {
		let exitCode = result.value;
		println("Echo succeeded with exit code: ".concat(string::fromI32(exitCode)));
		return exitCode;
	} else {
		println("Echo failed!");
		return 1;
	}
}
