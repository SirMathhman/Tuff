// Test: Character literal comparison
// Expected output: Exit code 0

fn main(): I32 => {
	let a: U8 = 'a';
	let b: U8 = 'b';
	
	// Test character comparisons
	if (a >= b) return 1;
	if (!(a < b)) return 2;
	if ('x' != 120U8) return 3;
	if ('A' == 'a') return 4;
	
	// Test in expressions
	let sum: U8 = 'a' + 1U8;  // 'b'
	if (sum != 'b') return 5;
	
	return 0;
}
