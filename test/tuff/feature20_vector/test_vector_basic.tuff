// Test basic Vector operations
// Uses stdlib Vector
use vector;

extern fn exit(code: I32): Void;

// Test
let mut vec = Vector::new<I32>(10);

if (vec.len() != 0USize) exit(1);
if (!vec.isEmpty()) exit(2);
if (vec.capacity() != 10USize) exit(3);

vec.push(1);
vec.push(2);
vec.push(3);

if (vec.len() != 3USize) exit(4);
if (vec.isEmpty()) exit(5);

vec.free();

0
