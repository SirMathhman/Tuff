// Test safe Array<T> primitive
// Tests bounds checking and safe access patterns

use array;
use option;

// Allocate stack space for small test array
let mut buffer: [I32; 5; 5] = [1, 2, 3, 4, 5];

// Create array wrapper around stack buffer
let mut arr = arrayFromRaw<I32>(&mut buffer[0], 5USize);

// Test initialization
let check1 = arrayLen<I32>(&arr) == 5USize;

// Test getting elements
let val0 = arrayGet<I32>(&arr, 0USize);
let check2 = val0 is Some<I32>;

let val4 = arrayGet<I32>(&arr, 4USize);
let check3 = val4 is Some<I32>;

// Test out of bounds get returns None
let valOob = arrayGet<I32>(&arr, 5USize);
let check4 = valOob is None<I32>;

// Test setting elements with bounds checking
let check5 = arraySet<I32>(&mut arr, 0USize, 10);
let check6 = arraySet<I32>(&mut arr, 4USize, 50);

// Test out of bounds set returns false
let check7 = !arraySet<I32>(&mut arr, 5USize, 100);

// Test with smaller array
let mut smallBuffer: [I32; 2; 2] = [100, 200];
let smallArr = arrayFromRaw<I32>(&mut smallBuffer[0], 2USize);
let check8 = arrayLen<I32>(&smallArr) == 2USize;

// Verify all checks
let allPass = check1 && check2 && check3 && check4 && check5 && check6 && check7 && check8;

if (allPass) 0 else 1

