// Test: Basic file read/write operations
use io;
use file;
use result;

extern fn exit(code: I32): Void;

// Test write and read
let testContent = "Hello, Tuff File I/O!";
let testPath = "test_temp_file.txt";

let writeResult = fileWriteAll(testPath, testContent);
if (writeResult is Err<Void, string>) {
	println("FAIL: write file");
	exit(1);
}

let readResult = fileReadAll(testPath);
if (readResult is Err<string, string>) {
	println("FAIL: read file");
	exit(2);
}

if (readResult is Ok<string, string>) {
	let content = readResult.value;
	if (!content.equals(testContent)) {
		println("FAIL: content mismatch");
		exit(3);
	}
}

println("PASS");
0
