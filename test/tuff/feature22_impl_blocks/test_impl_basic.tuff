// Test: Basic impl block with associated function and methods
struct Counter {
	value: I32
}

impl Counter {
	fn new(): Counter => {
		return Counter { 0 };
	}

	fn increment(this: *mut Counter): Void => {
		this.value = this.value + 1;
	}

	fn get(this: *Counter): I32 => this.value;
}

let mut c = Counter::new();
Counter::increment(&mut c);

// Expected: Returns 1 (incremented counter value)
Counter::get(&c);
