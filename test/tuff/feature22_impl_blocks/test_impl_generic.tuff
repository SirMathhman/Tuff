// Test: Impl block with generic struct
struct Pair<T> {
	first: T,
	second: T
}

impl<T> Pair<T> {
	fn new(a: T, b: T): Pair<T> => {
		return Pair<T> { a, b };
	}

	fn getFirst(self: *Pair<T>): T => self.first;

	fn getSecond(self: *Pair<T>): T => self.second;
}

let p = Pair<I32> { 10, 20 };
let a = p.first;
let b = p.second;

// Expected: a = 10, b = 20
a + b;
