// Test: Multiple impl blocks for same struct (not allowed in Tuff, but methods within one block)
struct Stack {
	top: I32,
	size: I32
}

impl Stack {
	fn new(): Stack => {
		return Stack { 0, 0 };
	}

	fn size(this: *Stack): I32 => this.size;

	fn push(this: *mut Stack): Void => {
		this.size = this.size + 1;
	}

	fn pop(this: *mut Stack): Void => {
		if (this.size > 0) {
			this.size = this.size - 1;
		}
	}
}

let mut s = Stack::new();
Stack::push(&mut s);
Stack::push(&mut s);
let sz = Stack::size(&s);
Stack::pop(&mut s);
let sz2 = Stack::size(&s);

// Expected: sz = 2, sz2 = 1
sz2;