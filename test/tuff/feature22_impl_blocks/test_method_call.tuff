// Test: Method call syntax (sugar for FQN calls)
struct Counter {
	value: I32
}

impl Counter {
	fn new(): Counter => {
		return Counter { 0 };
	}

	fn increment(this: *mut Counter): Void => {
		this.value = this.value + 1;
	}

	fn get(this: *Counter): I32 => this.value;
}

let mut c = Counter::new();

// Method call syntax: c.increment() instead of Counter::increment(&mut c)
c.increment();
c.increment();

// Expected: Returns 2 (incremented twice)
c.get();
