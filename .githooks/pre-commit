#!/usr/bin/env python3
"""
Pre-commit hook to enforce:
1. Maximum file line count of 500 lines (code files)
2. Markdown files (except README.md) must be in /docs folder
Excludes: target/, .git/, .githooks/, node_modules/, .vscode/, .idea/, and hidden directories.
"""

import subprocess
import sys
import os
from pathlib import Path
from typing import List, Tuple

MAX_LINES = 500
EXCLUDED_DIRS = {"target", ".git", ".githooks", "node_modules", ".vscode", ".idea"}


def is_excluded(file_path: str) -> bool:
    """Check if a file path is in an excluded directory or is an excluded file type."""
    # Exclude parser - known large file, to be refactored after type checker
    if "parser.rs" in file_path:
        return True

    # Exclude markdown files from line count check (they're checked separately for location)
    if file_path.endswith(".md"):
        return True

    # Exclude config and data files from line count check
    if file_path.endswith((".txt", ".toml", ".yaml", ".yml", ".json")):
        return True

    path = Path(file_path)

    # Check each part of the path
    for part in path.parts:
        if part in EXCLUDED_DIRS:
            return True
        # Exclude hidden files/directories except .gitignore
        if part.startswith(".") and file_path != ".gitignore":
            return True

    return False


def count_lines(file_path: str) -> int:
    """Count the number of lines in a file."""
    try:
        with open(file_path, "r", encoding="utf-8", errors="ignore") as f:
            # Read file content and count only LF characters (normalize CRLF to LF first)
            content = f.read().replace("\r\n", "\n")
            return content.count("\n") + (
                1 if content and not content.endswith("\n") else 0
            )
    except (IOError, OSError):
        return 0


def get_staged_files() -> List[str]:
    """Get list of staged files from git."""
    try:
        result = subprocess.run(
            ["git", "diff", "--cached", "--name-only", "--diff-filter=ACM"],
            capture_output=True,
            text=True,
            check=False,
        )
        if result.returncode == 0:
            return [f.strip() for f in result.stdout.split("\n") if f.strip()]
    except (FileNotFoundError, subprocess.SubprocessError):
        pass
    return []


def check_markdown_locations(files: List[str]) -> Tuple[bool, List[str]]:
    """
    Check that markdown files (except README.md) are in /docs folder.
    Returns: (all_valid, violations_list)
    """
    violations = []
    
    for file_path in files:
        # Check if it's a markdown file
        if not file_path.endswith(".md"):
            continue
        
        # README.md is allowed at root
        if file_path == "README.md":
            continue
        
        # All other markdown files must be in /docs folder
        if not file_path.startswith("docs/"):
            violations.append(file_path)
    
    return len(violations) == 0, violations


def check_file_sizes() -> Tuple[bool, List[str]]:
    """
    Check that all staged files are within the line limit.
    Returns: (all_valid, violations_list)
    """
    files = get_staged_files()
    violations = []

    for file_path in files:
        # Skip if file doesn't exist or is a directory
        if not os.path.isfile(file_path):
            continue

        # Skip if in excluded directory
        if is_excluded(file_path):
            continue

        # Count lines
        line_count = count_lines(file_path)

        # Check if exceeds limit
        if line_count > MAX_LINES:
            violations.append((file_path, line_count))

    return len(violations) == 0, violations


def format_violations(violations: List[Tuple[str, int]]) -> str:
    """Format violations for display."""
    lines = [f"Error: The following files exceed {MAX_LINES} lines:"]
    for file_path, line_count in violations:
        lines.append(f"  - {file_path} ({line_count} lines)")
    lines.append("Please split large files into smaller modules.")
    return "\n".join(lines)


def format_markdown_violations(violations: List[str]) -> str:
    """Format markdown location violations for display."""
    lines = ["Error: The following markdown files must be in /docs folder:"]
    for file_path in violations:
        lines.append(f"  - {file_path}")
    lines.append("(Exception: README.md is allowed at root)")
    return "\n".join(lines)


def main() -> int:
    """Main hook logic."""
    # Check file sizes
    all_sizes_valid, size_violations = check_file_sizes()
    
    # Check markdown locations
    files = get_staged_files()
    all_markdown_valid, markdown_violations = check_markdown_locations(files)
    
    all_valid = all_sizes_valid and all_markdown_valid
    
    if all_valid:
        print(f"✓ All files are within the {MAX_LINES} line limit.")
        print("✓ All markdown files are properly organized.")
        return 0
    else:
        if not all_sizes_valid:
            print(format_violations(size_violations), file=sys.stderr)
        if not all_markdown_valid:
            print(format_markdown_violations(markdown_violations), file=sys.stderr)
        return 1


if __name__ == "__main__":
    sys.exit(main())
