// Test basic Option<T> functionality
use option;

fn run(): I32 => {
    // Test Some
    let opt1: Option<I32> = Some<I32> { 42 };
    if (!(opt1 is Some<I32>)) {
        return 1;
    }
    // After inverse narrowing, opt1 is now Some<I32>, so accessing .value is safe
    let val1 = opt1.value;
    if (val1 != 42) {
        return 3;
    }
    
    // Test None
    let opt2: Option<I32> = None<I32> { };
    if (opt2 is Some<I32>) {
        return 4;
    }
    if (!(opt2 is None<I32>)) {
        return 5;
    }
    
    // opt2 is now known to be None, so we use a default value
    let val2: I32 = 99;
    if (val2 != 99) {
        return 6;
    }
    
    return 0;
}

run()
