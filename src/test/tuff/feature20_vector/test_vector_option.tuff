// Test impl blocks with Option-like return types
// Tests method calls returning union types
// Using explicit Some/None union instead of Option type alias to avoid Union_Option bug

struct IntBox {
    hasValue: Bool,
    value: I32
}

extern fn exit(code: I32): Void;

// Define local Some/None for this test
struct SomeI32 { value: I32 }
struct NoneI32 { }

impl IntBox {
    fn empty(): IntBox => {
        return IntBox { false, 0 };
    }

    fn with(val: I32): IntBox => {
        return IntBox { true, val };
    }

    // Return union type directly
    fn get(this: *IntBox): SomeI32 | NoneI32 => {
        if (this.hasValue) {
            return SomeI32 { this.value };
        }
        return NoneI32 { };
    }

    fn set(this: *mut IntBox, val: I32): Void => {
        this.value = val;
        this.hasValue = true;
    }
}

// Test
let mut box = IntBox::with(42);

// Get should return Some
let result = box.get();
if (result is NoneI32) exit(1);

// Set new value
box.set(99);
let result2 = box.get();
if (result2 is NoneI32) exit(2);

// Empty box should return None
let empty = IntBox::empty();
let result3 = empty.get();
if (result3 is SomeI32) exit(3);

// Success!
0
