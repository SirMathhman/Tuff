// Test Vector with method call syntax
// Uses stdlib Vector
use vector;
use option;

extern fn exit(code: I32): Void;

// Test using method call syntax
let mut vec = Vector::new<I32>(10);

// Test initial state
if (vec.len() != 0USize) exit(1);
if (!vec.isEmpty()) exit(2);
if (vec.capacity() != 10USize) exit(3);

// Test push
vec.push(10);
vec.push(20);
vec.push(30);

if (vec.len() != 3USize) exit(4);
if (vec.isEmpty()) exit(5);

// Test set and verify with get
vec.set(1, 100);

vec.free();

// Success!
0
