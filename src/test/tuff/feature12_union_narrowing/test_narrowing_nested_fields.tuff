// Test type narrowing with nested field access
use option;

struct Point {
    x: I32,
    y: I32
}
fn run(): I32 => {
    let pt: Option<Point> = Some<Point> { Point { 10, 20 } };
    
    if (pt is Some<Point>) {
        // Narrowed to Some<Point>, can access pt.value to get Point
        // Then access Point fields
        return pt.value.x + pt.value.y;  // Returns 30
    } else {
        return 0;
    }
}

run()
