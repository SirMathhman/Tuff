// Test basic type narrowing with union types
use option;
fn run(): I32 => {
    let opt: Option<I32> = Some<I32> { 42 };
    
    if (opt is Some<I32>) {
        // After 'is' check, opt is narrowed to Some<I32>
        // Can directly access opt.value without unwrapping
        return opt.value;  // Returns 42
    } else {
        return 0;
    }
}

run()
