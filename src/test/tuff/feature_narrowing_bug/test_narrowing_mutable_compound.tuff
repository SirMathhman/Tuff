// Test for type narrowing bug with mutable variables in compound conditions
// Bug: Type narrowing doesn't work properly when checking multiple variables
// with compound && conditions and then trying to access fields

use option;

fn testSimpleMutableNarrowing(): I32 => {
    let mut opt1: Option<I32> = Some<I32> { 42 };
    
    // Simple narrowing should work
    if (opt1 is Some<I32>) {
        let val = opt1.value;
        if (val == 42) {
            return 0;
        }
    }
    return 1;
}

fn testCompoundNarrowingBoth(): I32 => {
    let mut opt1: Option<I32> = Some<I32> { 42 };
    let mut opt2: Option<I32> = Some<I32> { 100 };
    
    // Compound narrowing - this should narrow both but might not
    if ((opt1 is Some<I32>) && (opt2 is Some<I32>)) {
        let val1 = opt1.value;  // BUG: This might fail - opt1 not narrowed
        let val2 = opt2.value;  // BUG: This might fail - opt2 not narrowed
        if (val1 == 42 && val2 == 100) {
            return 0;
        }
    }
    return 1;
}

fn testCompoundNarrowingNested(): I32 => {
    let mut opt1: Option<I32> = Some<I32> { 42 };
    let mut opt2: Option<I32> = Some<I32> { 100 };
    
    // Workaround: nest the conditions
    if (opt1 is Some<I32>) {
        if (opt2 is Some<I32>) {
            let val1 = opt1.value;
            let val2 = opt2.value;
            if (val1 == 42 && val2 == 100) {
                return 0;
            }
        }
    }
    return 1;
}

fn testCompoundNarrowingImmutable(): I32 => {
    let opt1: Option<I32> = Some<I32> { 42 };
    let opt2: Option<I32> = Some<I32> { 100 };
    
    // Same test but with immutable variables - should this work?
    if ((opt1 is Some<I32>) && (opt2 is Some<I32>)) {
        let val1 = opt1.value;
        let val2 = opt2.value;
        if (val1 == 42 && val2 == 100) {
            return 0;
        }
    }
    return 1;
}

// Run all tests
testSimpleMutableNarrowing();
testCompoundNarrowingBoth();
testCompoundNarrowingNested();
testCompoundNarrowingImmutable();
