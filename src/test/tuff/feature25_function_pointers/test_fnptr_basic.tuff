// Test basic function pointer functionality

extern fn exit(code: I32): Void;

// Simple function to test
fn add(a: I32, b: I32): I32 => a + b;
fn multiply(a: I32, b: I32): I32 => a * b;

// Function that takes a function pointer
fn apply(f: |I32, I32| => I32, x: I32, y: I32): I32 => f(x, y);

// Test
let addPtr: |I32, I32| => I32 = &add;
let result1 = addPtr(3, 4);
if (result1 != 7) exit(1);

let mulPtr: |I32, I32| => I32 = &multiply;
let result2 = mulPtr(3, 4);
if (result2 != 12) exit(2);

// Test passing function pointer to another function
let result3 = apply(&add, 10, 20);
if (result3 != 30) exit(3);

let result4 = apply(&multiply, 10, 20);
if (result4 != 200) exit(4);

// Success!
0
