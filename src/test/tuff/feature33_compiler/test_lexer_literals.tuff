// Test: Lexer numbers and strings
// Expected output: Exit code 0

use lexer;
use token;
use char_stream;
use testing;
use io;
use string;

fn main(): I32 => {
	let mut lexer = Lexer::new("42 123U64 3.14F32 \"hello\" 'a'");
	let tokens = lexer.tokenize();
	
	// Should have 6 tokens (5 literals + EOF)
	if (tokens.len() != 6USize) {
		println("Expected 6 tokens, got ".concat(tokens.len().toString()));
		return 1;
	}
	
	let t0 = tokens.get(0USize);
	let t1 = tokens.get(1USize);
	let t2 = tokens.get(2USize);
	let t3 = tokens.get(3USize);
	let t4 = tokens.get(4USize);
	
	if (t0 is Some<Token>) {
		if (t0.value.tokenType != TokenType.IntLiteral) return 2;
		if (!t0.value.value.equals("42")) return 3;
	} else return 2;
	
	if (t1 is Some<Token>) {
		if (t1.value.tokenType != TokenType.IntLiteral) return 4;
		if (!t1.value.value.equals("123U64")) return 5;
	} else return 4;
	
	if (t2 is Some<Token>) {
		if (t2.value.tokenType != TokenType.FloatLiteral) return 6;
		if (!t2.value.value.equals("3.14F32")) return 7;
	} else return 6;
	
	if (t3 is Some<Token>) {
		if (t3.value.tokenType != TokenType.StringLiteral) return 8;
		if (!t3.value.value.equals("hello")) return 9;
	} else return 8;
	
	if (t4 is Some<Token>) {
		if (t4.value.tokenType != TokenType.CharLiteral) return 10;
	} else return 10;
	
	return 0;
}
