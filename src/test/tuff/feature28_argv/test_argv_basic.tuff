// Test: Command line arguments
use io;
use argv;
use array;
use primitives;

in let args: Array<string>;

fn main(): I32 => {
	// Access via get() method for safety
	let progName = args.get(0USize);
	if (progName is Some<string>) {
		println("Program name: ".concat(progName.value));
	}
	
	let count = args.len();
	if (count > 1) {
		let firstArg = args.get(1USize);
		if (firstArg is Some<string>) {
			println("First argument: ".concat(firstArg.value));
		}
	}
	
	// Iterate all args
	let mut i: USize = 0USize;
	while (i < count) {
		let arg = args.get(i);
		if (arg is Some<string>) {
			println("Arg ".concat(i.toString()).concat(": ").concat(arg.value));
		}
		i = i + 1USize;
	}
	
	return 0;
}
