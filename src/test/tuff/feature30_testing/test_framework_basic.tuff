// Test: Testing framework basic functionality
// Expected output: All tests pass, exit code 0

use testing;
use io;

// Test functions - just return true/false directly

fn testAddition(): Bool => {
	return assertEqualI32(2 + 2, 4);
}

fn testBoolTrue(): Bool => {
	return assertTrue(true);
}

fn testBoolFalse(): Bool => {
	return assertFalse(false);
}

fn testStringEqual(): Bool => {
	return assertEqualString("hello", "hello");
}

fn testMultipleAsserts(): Bool => {
	return assertTrue(1 < 2) && assertEqualI32(5, 5) && assertFalse(false);
}

fn main(): I32 => {
	// Run tests manually since we don't have TestSuite yet
	let mut passed: I32 = 0;
	let mut failed: I32 = 0;
	
	if (testAddition()) {
		println("  [PASS] addition");
		passed = passed + 1;
	} else {
		println("  [FAIL] addition");
		failed = failed + 1;
	}
	
	if (testBoolTrue()) {
		println("  [PASS] bool true");
		passed = passed + 1;
	} else {
		println("  [FAIL] bool true");
		failed = failed + 1;
	}
	
	if (testBoolFalse()) {
		println("  [PASS] bool false");
		passed = passed + 1;
	} else {
		println("  [FAIL] bool false");
		failed = failed + 1;
	}
	
	if (testStringEqual()) {
		println("  [PASS] string equal");
		passed = passed + 1;
	} else {
		println("  [FAIL] string equal");
		failed = failed + 1;
	}
	
	if (testMultipleAsserts()) {
		println("  [PASS] multiple asserts");
		passed = passed + 1;
	} else {
		println("  [FAIL] multiple asserts");
		failed = failed + 1;
	}
	
	println("");
	println("Results: ".concat(string::fromI32(passed)).concat("/").concat(string::fromI32(passed + failed)).concat(" passed"));
	
	return if (failed == 0) 0 else 1;
}
