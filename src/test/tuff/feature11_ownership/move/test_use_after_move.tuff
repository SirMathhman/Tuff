// Test: Use-after-move for allocated memory
// This should fail compilation because 'ptr' is moved to 'ptr2'
// Expected error: moved

extern fn malloc(size: USize): *mut [I32] & #free;
extern fn free(ptr: *mut [I32] & #free): Void;

fn main(): I32 => {
    let ptr: *mut [I32] & #free = malloc(4);
    let ptr2 = ptr;   // ptr is moved to ptr2
    ptr[0] = 42;      // ERROR: use of moved value 'ptr'
    return 0;
}
