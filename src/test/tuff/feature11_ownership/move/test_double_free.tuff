// Test: Double free prevention - cannot use moved pointer
// This should fail compilation because 'ptr' is moved then freed again
// Expected error: moved

extern fn malloc(size: USize): *mut [I32] & #free;
extern fn free(ptr: *mut [I32] & #free): Void;

fn main(): I32 => {
    let ptr: *mut [I32] & #free = malloc(4);
    free(ptr);   // ptr is moved/consumed by free
    free(ptr);   // ERROR: use of moved value 'ptr'
    return 0;
}
