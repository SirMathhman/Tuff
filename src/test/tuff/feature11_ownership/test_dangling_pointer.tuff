// Test: Dangling pointer detection - pointer outlives referenced variable
// This should fail compilation because 'p' references 'x' which goes out of scope
// Expected error: dangling

fn getDanglingPointer(): *I32 => {
    let x: I32 = 42;
    let p: *I32 = &x;
    return p;  // ERROR: x goes out of scope, p would dangle
}

fn main(): I32 => {
    let ptr = getDanglingPointer();
    return *ptr;  // Would dereference dangling pointer
}
