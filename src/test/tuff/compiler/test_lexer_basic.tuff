// Test: Lexer basic tokenization
// Expected output: Exit code 0

use compiler::lexer;
use compiler::token;
use io;

fn main(): I32 => {
	// Test simple tokens
	let mut lexer = Lexer::new("let x = 42;");
	let tokens = lexer.tokenize();
	
	// Should have: let, x, =, 42, ;, EOF = 6 tokens
	if (tokens.len() != 6USize) {
		println("Expected 6 tokens, got ".concat(tokens.len().toString()));
		return 1;
	}
	
	// Test keywords
	let mut lexer2 = Lexer::new("fn struct enum");
	let tokens2 = lexer2.tokenize();
	
	if (tokens2.len() != 4USize) {
		println("Expected 4 tokens, got ".concat(tokens2.len().toString()));
		return 2;
	}
	
	// Test operators
	let mut lexer3 = Lexer::new("== != <= >= => ::");
	let tokens3 = lexer3.tokenize();
	
	if (tokens3.len() != 7USize) {
		println("Expected 7 tokens, got ".concat(tokens3.len().toString()));
		return 3;
	}
	
	println("Lexer basic tokenization tests passed");
	return 0;
}
