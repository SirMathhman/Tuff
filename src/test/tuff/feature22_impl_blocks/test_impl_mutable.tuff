// Test: Impl block with mutable and immutable methods
struct Container {
	contents: I32
}

impl Container {
	fn new(val: I32): Container => {
		return Container { val };
	}

	fn peek(this: *Container): I32 => this.contents;

	fn replace(this: *mut Container, val: I32): I32 => {
		let old = this.contents;
		this.contents = val;
		return old;
	}
}

let mut b = Container::new(42);
let v1 = Container::peek(&b);
let old = Container::replace(&mut b, 99);
let v2 = Container::peek(&b);

// Expected: v1 = 42, old = 42, v2 = 99
v2;