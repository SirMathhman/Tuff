// Test: Method call on immutable object (read-only method)
struct Container {
	value: I32
}

impl Container {
	fn new(v: I32): Container => {
		return Container { v };
	}

	fn get(this: *Container): I32 => this.value;
}

// Immutable variable - can only call immutable methods
let b = Container::new(42);

// This should work - get() only needs *Container (immutable reference)
b.get();
