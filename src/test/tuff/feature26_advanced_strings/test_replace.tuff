// Test: replace method
use string;
use io;

extern fn exit(code: I32): Void;

// Test basic replace
let s1 = "hello world";
let r1 = s1.replace("world", "Tuff");
if (!r1.equals("hello Tuff")) {
	println("FAIL: basic replace");
	exit(1);
}

// Test replace multiple occurrences
let s2 = "foo bar foo baz foo";
let r2 = s2.replace("foo", "qux");
if (!r2.equals("qux bar qux baz qux")) {
	println("FAIL: replace multiple");
	exit(2);
}

// Test replace with empty string (remove)
let s3 = "hello world";
let r3 = s3.replace("world", "");
if (!r3.equals("hello ")) {
	println("FAIL: replace with empty");
	exit(3);
}

// Test replace non-existent
let s4 = "hello world";
let r4 = s4.replace("xyz", "abc");
if (!r4.equals("hello world")) {
	println("FAIL: replace non-existent");
	exit(4);
}

println("PASS");
0
