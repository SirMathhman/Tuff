// Test: split method
use string;
use io;
use vector;

extern fn exit(code: I32): Void;

// Test basic split
let s1 = "hello,world,foo";
let mut parts1 = s1.split(",");
if (parts1.len() != 3USize) {
	println("FAIL: split count");
	exit(1);
}

let p0 = parts1.get(0USize);
if (p0 is None<string>) {
	println("FAIL: get part 0");
	exit(2);
}
if (p0 is Some<string>) {
	let part0 = p0.value;
	if (!part0.equals("hello")) {
		println("FAIL: part 0 value");
		exit(3);
	}
}

let p1 = parts1.get(1USize);
if (p1 is None<string>) {
	println("FAIL: get part 1");
	exit(4);
}
if (p1 is Some<string>) {
	let part1 = p1.value;
	if (!part1.equals("world")) {
		println("FAIL: part 1 value");
		exit(5);
	}
}

let p2 = parts1.get(2USize);
if (p2 is None<string>) {
	println("FAIL: get part 2");
	exit(6);
}
if (p2 is Some<string>) {
	let part2 = p2.value;
	if (!part2.equals("foo")) {
		println("FAIL: part 2 value");
		exit(7);
	}
}

// Test split with no delimiter found
let s2 = "hello";
let mut parts2 = s2.split(",");
if (parts2.len() != 1USize) {
	println("FAIL: split no delimiter");
	exit(8);
}

// Test split with multi-char delimiter
let s3 = "foo::bar::baz";
let mut parts3 = s3.split("::");
if (parts3.len() != 3USize) {
	println("FAIL: split multi-char count");
	exit(9);
}

let p3_0 = parts3.get(0USize);
if (p3_0 is None<string>) {
	println("FAIL: get multichar part 0");
	exit(10);
}
if (p3_0 is Some<string>) {
	if (!p3_0.value.equals("foo")) {
		println("FAIL: multichar part 0 value");
		exit(11);
	}
}

// Test split with empty parts
let s4 = "a,,b";
let mut parts4 = s4.split(",");
if (parts4.len() != 3USize) {
	println("FAIL: split empty parts count");
	exit(12);
}

let p4_1 = parts4.get(1USize);
if (p4_1 is None<string>) {
	println("FAIL: get empty part");
	exit(13);
}
if (p4_1 is Some<string>) {
	if (!p4_1.value.isEmpty()) {
		println("FAIL: empty part should be empty");
		exit(14);
	}
}

parts1.free();
parts2.free();
parts3.free();
parts4.free();

println("PASS");
0
