extern use { createArray } from lib;

extern fn createArray<T>(length : USize) : *mut [T];

fn List<T>() => {
    let mut array : *mut [T] = createArray(10);

    fn set(index : USize, element : T) => {
        array[index] = element;
        this.this
    }

    fn getFirst() => array[0];

    this
}

List<I32>()
    .set(0, 100)
    .getFirst();

extern fn readContent() : *Str;
extern fn println(content : *Str) : Void;

println(readContent());

100