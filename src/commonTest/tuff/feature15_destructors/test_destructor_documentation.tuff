// Test: Documentation for String destructor support
// This test documents that String types are designed to have destructors
// 
// When the String type is used (not byte array literals), the compiler
// will automatically call string_destroy when String variables go out of scope.
//
// For JS: string_destroy is explicitly called (no-op since JS has GC)
// For C++: std::string has RAII, destructor called automatically
//
// The getDestructor() function in CodeGeneratorJS now recognizes
// the String type and returns "string_destroy" as the destructor name.

fn myDestructor(val: I32): Void => {
    // Dummy destructor for testing
}

fn test(): I32 => {
    // Test that intersection types with destructors work
    let x: I32 & ~myDestructor = 42;
    x
}

test()
