// Test destructor called before break statement

fn myDestructor(val: I32): Void => {
    // In a real scenario, this would free resources
}

fn test(): I32 => {
    let mut result: I32 = 0;
    loop {
        let x: I32 & ~myDestructor = 5;
        result = x;
        break;
        // x's destructor should be called before break
    }
    result
}

test()
