// Test vector pop

fn run(): I32 => {
    let mut vec: Vector<I32> = vectorNew<I32>();
    
    vec = vectorPush<I32>(vec, 10);
    vec = vectorPush<I32>(vec, 20);
    vec = vectorPush<I32>(vec, 30);
    
    let popped: Some<I32> | None<I32> = vectorPop<I32>(vec);
    if (popped is Some<I32>) {
        if (popped.value != 30) {
            return 1;
        }
    } else {
        return 2;
    }
    
    if (vectorLen<I32>(vec) != 2) {
        return 3;
    }
    
    vectorFree<I32>(vec);
    return 0;
}

run()
