// Test vector push and get

fn run(): I32 => {
    let mut vec: Vector<I32> = vectorNew<I32>();
    
    vec = vectorPush<I32>(vec, 42);
    vec = vectorPush<I32>(vec, 100);
    
    if (vectorLen<I32>(vec) != 2) {
        return 1;
    }
    
    let first: Some<I32> | None<I32> = vectorGet<I32>(vec, 0);
    if (first is Some<I32>) {
        if (first.value != 42) {
            return 2;
        }
    } else {
        return 3;
    }
    
    let second: Some<I32> | None<I32> = vectorGet<I32>(vec, 1);
    if (second is Some<I32>) {
        if (second.value != 100) {
            return 4;
        }
    } else {
        return 5;
    }
    
    vectorFree<I32>(vec);
    return 0;
}

run()
