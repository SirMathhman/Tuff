// Test basic Vector operations

struct Some<T> {
    value: T
}

struct None<T> {
}

extern fn tuff_malloc<T>(size: USize): *mut [T];
extern fn tuff_realloc<T>(ptr: *mut [T], newSize: USize): *mut [T];
extern fn tuff_free<T>(ptr: *mut [T]): Void;
extern fn exit(code: I32): Void;

struct Vector<T> {
    data : *mut [T],
    length : USize,
    capacity : USize
}

fn vectorNew<T>(): Vector<T> => Vector<T> { tuff_malloc<T>(sizeOf(T) * 10USize), 0USize, 10USize };

fn vectorLen<T>(vec: *Vector<T>): USize => vec.length;

fn vectorCapacity<T>(vec: *Vector<T>): USize => vec.capacity;

fn vectorIsEmpty<T>(vec: *Vector<T>): Bool => vec.length == 0USize;

fn vectorPush<T>(vec: *mut Vector<T>, value: T): Void => {
    if (vec.length >= vec.capacity) {
        let newCapacity: USize = vec.capacity * 2USize;
        vec.data = tuff_realloc<T>(vec.data, sizeOf(T) * newCapacity);
        vec.capacity = newCapacity;
    }
    
    vec.data[vec.length] = value;
    vec.length = vec.length + 1USize;
}

fn vectorGet<T>(vec: *Vector<T>, index: USize): Some<T> | None<T> => {
    if (index >= vec.length) {
        return None<T> { };
    }
    
    let ptr: *T = vec.data + index;
    return Some<T> { *ptr };
}

fn vectorFree<T>(vec: *mut Vector<T>): Void => {
    tuff_free<T>(vec.data);
}

// Test
let mut vec = vectorNew<I32>();

if (vectorLen<I32>(&vec) != 0USize) exit(1);
if (!vectorIsEmpty<I32>(&vec)) exit(2);
if (vectorCapacity<I32>(&vec) != 10USize) exit(3);

vectorPush<I32>(&mut vec, 42);
vectorPush<I32>(&mut vec, 100);
vectorPush<I32>(&mut vec, 200);

if (vectorLen<I32>(&vec) != 3USize) exit(4);
if (vectorIsEmpty<I32>(&vec)) exit(5);

let first = vectorGet<I32>(&vec, 0USize);
if (first is None<I32>) exit(6);

let second = vectorGet<I32>(&vec, 1USize);
if (second is None<I32>) exit(8);

let third = vectorGet<I32>(&vec, 2USize);
if (third is None<I32>) exit(10);

let invalid = vectorGet<I32>(&vec, 3USize);
if (invalid is Some<I32>) exit(12);

vectorFree<I32>(&mut vec);

0
