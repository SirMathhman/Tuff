// Test basic Option<T> functionality

struct Some<T> {
    value: T
}

struct None<T> {
}

fn main(): I32 => {
    // Test Some
    let opt1: Some<I32> | None<I32> = Some<I32> { 42 };
    if (!(opt1 is Some<I32>)) {
        return 1;
    }
    if (opt1 is None<I32>) {
        return 2;
    }
    
    // Unwrap with type narrowing
    if (opt1 is Some<I32>) {
        let val1 = opt1.value;
        if (val1 != 42) {
            return 3;
        }
    } else {
        return 10;
    }
    
    // Test None
    let opt2: Some<I32> | None<I32> = None<I32> { };
    if (opt2 is Some<I32>) {
        return 4;
    }
    if (!(opt2 is None<I32>)) {
        return 5;
    }
    
    // unwrapOr with None (use default)
    let mut val2: I32 = 99;
    if (opt2 is Some<I32>) {
        val2 = opt2.value;
    }
    if (val2 != 99) {
        return 6;
    }
    
    return 0;
}
