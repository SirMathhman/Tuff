// Test type narrowing with None variant

struct Some<T> {
    value: T
}

struct None<T> {
}

type Option<T> = Some<T> | None<T>;

fn run(): I32 => {
    let opt: Option<I32> = None<I32> { };
    
    if (opt is Some<I32>) {
        return 100;
    } else {
        // opt is still Option<I32> in else branch (no narrowing)
        return 0;
    }
}

run()
