// Result type for operations that can fail with an error message

// Unit type for Result<Unit, E> when there's no meaningful success value
struct Unit { }

struct Ok<T, E> {
    value: T
}

struct Err<T, E> {
    error: E
}

type Result<T, E> = Ok<T, E> | Err<T, E>;

impl<T, E> Result<T, E> {
    fn isOk(this: Result<T, E>): Bool => this is Ok<T, E>;
    fn isErr(this: Result<T, E>): Bool => this is Err<T, E>;
}
