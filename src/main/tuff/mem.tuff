// Memory allocation primitives

extern use stdlib;

type Alloc<Type> = *mut [Type] & #free;

extern fn malloc<Type>(size: USize): Alloc<Type>;
extern fn realloc<Type>(ptr: Alloc<Type>, newSize: USize): Alloc<Type>;
extern fn free<Type>(ptr: Alloc<Type>): Void;

extern fn memcpy(dest: *mut Void, src: *Void, count: USize): Void;

// Allocate array of T with given count
