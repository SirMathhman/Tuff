// Simple testing framework for Tuff
// Uses function pointers since closures aren't available

use io;
use string;
use primitives;

// ============ Assertion Helpers ============
// Using 'got' and 'want' to avoid reserved words 'actual' and 'expect'

// Assert that a boolean value is true
fn assertTrue(value: Bool): Bool => value;

// Assert that a boolean value is false
fn assertFalse(value: Bool): Bool => !value;

// Assert that two I32 values are equal
fn assertEqualI32(got: I32, want: I32): Bool => got == want;

// Assert that two USize values are equal
fn assertEqualUSize(got: USize, want: USize): Bool => got == want;

// Assert that two Bool values are equal
fn assertEqualBool(got: Bool, want: Bool): Bool => got == want;

// Assert that two strings are equal
fn assertEqualString(got: string, want: string): Bool => got.equals(want);

// Assert that an I32 is greater than another
fn assertGreaterI32(got: I32, threshold: I32): Bool => got > threshold;

// Assert that an I32 is less than another
fn assertLessI32(got: I32, threshold: I32): Bool => got < threshold;


