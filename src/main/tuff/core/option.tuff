// Option<T> - represents an optional value
// Either Some<T> (contains a value) or None<T> (empty)

struct Some<T> {
    value: T
}

struct None<T> {
}
// Type alias for the union of Some<T> and None<T>
type Option<T> = Some<T> | None<T>;

impl<T> Option<T> {
    fn isSome(this: Option<T>): Bool => this is Some<T>;
    fn isNone(this: Option<T>): Bool => this is None<T>;
}
