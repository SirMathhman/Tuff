// Result type for operations that can fail with an error message

struct Ok<T> {
    value: T
}

struct Err<E> {
    error: E
}

type Result<T, E> = Ok<T> | Err<E>;

impl<T, E> Result<T, E> {
    fn isOk(this: Result<T, E>): Bool => this is Ok<T>;
    fn isErr(this: Result<T, E>): Bool => this is Err<E>;
}
