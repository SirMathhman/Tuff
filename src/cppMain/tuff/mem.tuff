// Memory allocation primitives

use extern stdlib;

type Allocated<Type, Length : USize> = *mut [Type; 0; Length] & ~free;

extern fn malloc<Type, Length : USize>(size: SizeOf<Type> * Length): Allocated<Type, Length>;
extern fn free<Type, Length : USize>(ptr: Allocated<Type, Length>): Void;

extern fn exit(code: I32): Void;

