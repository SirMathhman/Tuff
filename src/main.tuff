// This test case will be highly instructive

// This is valid
fn getFirst(array : [I32; 1; 3]) => array[0];

let mut array : [I32; 0; 3];
array[0] = 120;
getFirst(array);

/*
This is invalid, we don't initialize array[0].
Hence, array is not [I32; 1; 3]

fn getFirst(array : [I32; 1; 3]) => array[0];

let mut array : [I32; 0; 3];
getFirst(array);
*/