<?xml version="1.0"?>
<!DOCTYPE module PUBLIC "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN" "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
	<property name="charset" value="UTF-8" />
	<property name="fileExtensions" value="java" />

	<!-- Enforce maximum file length of 520 lines (increased for App.java with new features) -->
	<module name="FileLength">
		<property name="max" value="520" />
	</module>

	<module name="TreeWalker">
		<!-- Enforce maximum method length of 50 lines -->
		<module name="MethodLength">
			<property name="max" value="50" />
			<property name="countEmpty" value="false" />
			<property name="tokens" value="METHOD_DEF,COMPACT_CTOR_DEF" />
		</module>

		<!-- Enforce maximum boolean fields of 3 per class -->
		<module name="io.github.sirmathhman.tuff.checkstyle.BooleanFieldCountCheck">
			<property name="max" value="3" />
		</module>

		<!-- Detect Feature Envy code smell (parameter accessed >65 times) -->
		<module name="io.github.sirmathhman.tuff.checkstyle.FeatureEnvyCheck">
			<property name="threshold" value="65" />
		</module>

		<!-- Enforce maximum parameters of 7 per method (increased for parseStatement with type aliases) -->
		<module name="ParameterNumber">
			<property name="max" value="7" />
		</module>

		<!-- Enforce maximum record components of 6 per record (increased for ProcessContext with type
		aliases) -->
		<module name="RecordComponentNumber">
			<property name="max" value="6" />
		</module>

		<module name="ParameterAssignment" />
	</module>
</module>