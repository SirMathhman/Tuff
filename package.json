{
  "name": "tuff",
  "version": "0.1.0",
  "description": "A typed expression interpreter with support for functions, lambdas, and advanced type system",
  "private": true,
  "main": "./src/utils/interpret.ts",
  "type": "module",
  "files": [
    "src"
  ],
  "exports": {
    ".": "./src/utils/interpret.ts",
    "./interpret": "./src/utils/interpret.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bun": "latest",
    "ts-morph": "^27.0.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.53.1"
  },
  "dependencies": {
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "madge": "^8.0.0",
    "prettier": "^3.8.1"
  },
  "scripts": {
    "dupfind": "./tools/dupfind.exe src --min-nodes 20",
    "prepare": "husky",
    "lint": "tsc --noEmit && eslint . --ext .ts,.tsx",
    "lint:fix": "tsc --noEmit && eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "test": "bun test",
    "cpd": "JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64 PATH=\"/usr/lib/jvm/java-21-openjdk-amd64/bin:$PATH\" ./tools/pmd-bin-7.20.0/bin/pmd cpd --dir src tests --language typescript --minimum-tokens 35 --ignore-identifiers --ignore-literals",
    "inline-check": "bun ./tools/inline-check.ts",
    "check:structure": "bun ./tools/check-dir-structure.ts",
    "check:subdir-deps": "bun ./tools/check-subdir-deps.ts",
    "visualize": "npx madge --image ./docs/images/graph.svg src tests",
    "check:circular": "npx madge --circular src"
  }
}
