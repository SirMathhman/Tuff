{
  "name": "tuff",
  "version": "0.0.1",
  "description": "A self-hosted compiler for a new systems programming language with Rust, TypeScript, and Kotlin inspiration",
  "type": "module",
  "bin": {
    "tuff": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./lexer": "./dist/lexer/index.js",
    "./parser": "./dist/parser/index.js",
    "./ast": "./dist/ast/index.js",
    "./analyzer": "./dist/analyzer/index.js",
    "./codegen": "./dist/codegen/index.js"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "dev": "bun run --watch src/cli/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "latest",
    "@types/eslint": "^8.56.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  }
}
