{
  "name": "tuff",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "prepare": "husky install",
    "build": "tsc",
    "cpd": "pmd cpd src tests --language typescript --minimum-tokens 35",
    "start": "bun ./src/index.ts && (bun ./src/main.js; echo \"Exit code: $?\"; exit 0)",
    "watch": "nodemon --watch src --watch src/main.tuff --ext ts,tuff --exec npm start",
    "lint": "npm run lint:tsc && npm run lint:eslint",
    "lint:eslint": "eslint src tests",
    "lint:tsc": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SirMathhman/Tuff.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/SirMathhman/Tuff/issues"
  },
  "homepage": "https://github.com/SirMathhman/Tuff#readme",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.1.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
