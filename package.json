{
  "name": "tuff",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "cpd": "pmd cpd src tests --language typescript --minimum-tokens 35 --ignore-literals --ignore-identifiers",
    "prepare": "husky install",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "bun run src/index.ts",
    "lint": "tsc --noEmit && eslint 'src/**/*.{ts,js}'",
    "format": "prettier --write 'src/**/*.{ts,js,json,md}'",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "husky": "^8.0.0"
  }
}
