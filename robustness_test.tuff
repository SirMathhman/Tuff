// Comprehensive robustness test for Tuff compiler
// Tests: structs, generics, functions, control flow, pointers, arrays, modules

struct Point {
    x: I32,
    y: I32
}

struct Container<T> {
    value: T,
    count: I32
}

enum Status {
    Ok,
    Err
}

fn add(a: I32, b: I32): I32 => a + b;

fn multiply(x: I32, y: I32): I32 => x * y;

fn negate(x: I32): I32 => -x;

fn is_positive(x: I32): Bool => x > 0;

fn absolute_value(x: I32): I32 => {
    if (is_positive(x)) {
        x
    } else {
        negate(x)
    }
}

fn max(a: I32, b: I32): I32 => {
    if (a > b) {
        a
    } else {
        b
    }
}

fn fibonacci(n: I32): I32 => {
    if (n <= 1) {
        n
    } else {
        add(fibonacci(add(n, negate(1))), fibonacci(add(n, negate(2))))
    }
}

fn make_point(x: I32, y: I32): Point => Point { x, y };

fn distance_from_origin(p: Point): I32 => {
    let x_sq = multiply(p.x, p.x);
    let y_sq = multiply(p.y, p.y);
    add(x_sq, y_sq)
}

fn point_in_quadrant(p: Point): I32 => {
    if (p.x > 0) {
        if (p.y > 0) {
            1
        } else {
            4
        }
    } else {
        if (p.y > 0) {
            2
        } else {
            3
        }
    }
}

fn swap_point_coordinates(p: Point): Point => Point { p.y, p.x };

fn generic_identity<T>(value: T): T => value;

fn generic_pair<T>(a: T, b: T): I32 => 2;

fn sum_array(arr: [I32; 10; 10]): I32 => {
    let mut sum = 0;
    let mut i = 0;
    while (i < 3) {
        sum = sum + arr[i];
        i = i + 1;
    }
    sum
}

fn count_to(n: I32): I32 => {
    let mut i = 0;
    let mut result = 0;
    loop {
        if (i >= n) {
            break;
        }
        result = result + i;
        i = i + 1;
    }
    result
}

fn nested_loops(): I32 => {
    let mut outer = 0;
    let mut result = 0;
    loop {
        if (outer >= 3) {
            break;
        }
        let mut inner = 0;
        loop {
            if (inner >= 2) {
                break;
            }
            result = result + 1;
            inner = inner + 1;
        }
        outer = outer + 1;
    }
    result
}

fn conditional_chain(x: I32): I32 => {
    if (x < 0) {
        0
    } else if (x < 10) {
        1
    } else if (x < 20) {
        2
    } else {
        3
    }
}

fn pointer_test(p: *I32): I32 => *p;

fn mutable_pointer_test<a>(p: *a mut I32): Void => {
    *p = *p + 1;
}

// Main test suite
fn main(): I32 => {
    let p1 = make_point(3, 4);
    let p2 = make_point(-2, 5);
    let p3 = swap_point_coordinates(p1);

    let sum1 = add(10, 20);
    let sum2 = add(sum1, add(5, 5));
    let prod = multiply(sum2, 2);

    let abs_neg = absolute_value(negate(15));
    let max_val = max(42, 100);

    let fib5 = fibonacci(5);

    let dist = distance_from_origin(p1);
    let quad = point_in_quadrant(p2);
    let quad_swap = point_in_quadrant(p3);

    let id_val = generic_identity<I32>(99);
    let pair_count = generic_pair<I32>(1, 2);

    let arr: [I32; 10; 10] = [1, 2, 3, 0, 0, 0, 0, 0, 0, 0];
    let arr_sum = sum_array(arr);

    let count_result = count_to(5);
    let nested = nested_loops();

    let cond1 = conditional_chain(negate(1));
    let cond2 = conditional_chain(5);
    let cond3 = conditional_chain(15);
    let cond4 = conditional_chain(50);

    let ptr_val = pointer_test(&42);

    let mut mutable_val = 50;
    mutable_pointer_test(&mut mutable_val);

    let final_result = add(
        add(prod, fib5),
        add(arr_sum, nested)
    );

    final_result
}
