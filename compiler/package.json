{
  "name": "tuff",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "tsc --noEmit && eslint ./src --fix --ext .ts",
    "lint:tsc:file": "tsc --noEmit",
    "lint:eslint:file": "eslint --fix --ext .ts",
    "test": "bun test",
    "cpd": "pmd cpd --dir src --minimum-tokens 50 --language typescript --ignore-literals --ignore-identifiers",
    "check-dupes": "bun run scripts/check-duplicate-expressions.ts",
    "inline-vars": "bun run scripts/inline-single-use-variables.ts",
    "inline-fns": "bun run scripts/inline-single-use-functions.ts",
    "check-string-dupes": "bun run scripts/check-duplicate-string-substrings.ts",
    "agent": "npx tsx ../agent/index.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@opencode-ai/plugin": "^1.14.46",
    "@types/bun": "^1.3.14",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "ts-morph": "^28.0.0",
    "typescript-eslint": "^8.59.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
