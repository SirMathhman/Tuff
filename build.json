{
  "sourceRoot": "src",
  "outputRoot": "dist",
  "sourceSets": {
    "commonMain": {
      "path": "src/commonMain/tuff",
      "type": "common"
    },
    "jsMain": {
      "path": "src/jsMain/tuff",
      "type": "platform",
      "target": "js",
      "output": "dist/js/tuff",
      "extension": ".js"
    },
    "cppMain": {
      "path": "src/cppMain/tuff",
      "type": "platform",
      "target": "cpp",
      "output": "dist/native/tuff",
      "extension": ".cpp"
    }
  },
  "targets": {
    "js": {
      "sourceSets": ["commonMain", "jsMain"],
      "output": "dist/js/tuff"
    },
    "cpp": {
      "sourceSets": ["commonMain", "cppMain"],
      "output": "dist/native/tuff"
    }
  },
  "defaultTarget": "js"
}
