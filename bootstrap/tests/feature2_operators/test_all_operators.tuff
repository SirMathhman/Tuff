// Arithmetic operators
let a = 10;
let b = 3;
let add = a + b;
let sub = a - b;
let mul = a * b;
let div = a / b;
let mod = a % b;

// Comparison operators
let eq = a == b;
let neq = a != b;
let lt = a < b;
let gt = a > b;
let lte = a <= b;
let gte = a >= b;

// Logical operators (use immutable booleans for operands)
let t = true;
let f = false;
let andResult = t && f;
let orResult = t || f;
let notResult = !t;

// Final value (testing arithmetic since it's most versatile)
mul
