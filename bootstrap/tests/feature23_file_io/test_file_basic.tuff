// Test basic file IO operations
// Expected exit code: 0
use file;
use string;

// Test file_writeAll and file_readAll
let writeResult = file_writeAll("test_output.txt", "Hello, Tuff!");

// Check write succeeded (0 = success)
if (writeResult != 0) {
    1
} else {
    // Read it back
    let content = file_readAll("test_output.txt");
    
    // Verify content matches (empty string means failure)
    if (string_length(content) == 0) {
        2
    } else {
        if (string_equals(content, "Hello, Tuff!")) {
            0  // Success
        } else {
            3  // Content mismatch
        }
    }
}
