// Test destructor called in nested scopes
// The destructor should be called when each variable goes out of scope

fn myDestructor(val: I32): Void => {
    // In a real scenario, this would free resources
}

fn test(): I32 => {
    let a: I32 & ~myDestructor = 10;
    {
        let b: I32 & ~myDestructor = 20;
        // b's destructor is called here
    }
    // a's destructor is called when function returns
    a
}

test()
