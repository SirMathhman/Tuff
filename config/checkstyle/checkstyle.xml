<?xml version="1.0"?>
<!DOCTYPE module PUBLIC "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN" "https://checkstyle.org/dtds/configuration_1_3.dtd">
<module name="Checker">
	<property name="severity" value="error" />

	<!-- Limit line length to 120 chars -->
	<module name="LineLength">
		<property name="max" value="120" />
	</module>

	<!-- Disallow trailing whitespace (via regex) -->
	<module name="RegexpSingleline">
		<property name="format" value="\s+$" />
		<property name="message" value="Trailing whitespace found." />
	</module>

	<module name="TreeWalker">
		<!-- Ban the use of 'null' word -->
		<module name="IllegalToken">
			<property name="tokens" value="LITERAL_NULL" />
		</module>

		<!-- Ban the use of 'throw' word -->
		<module name="IllegalToken">
			<property name="tokens" value="LITERAL_THROW" />
		</module>

		<!-- Enforce max cyclomatic complexity -->
		<module name="CyclomaticComplexity">
			<property name="max" value="15" />
		</module>
	</module>
</module>