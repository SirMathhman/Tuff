// Test module declarations

module Math {
    fn square(x) {
        return x * x;
    }
    
    fn cube(x) {
        return x * x * x;
    }
}

module String {
    fn reverse(s) {
        // For now, just demonstrate the syntax
        return s;
    }
}

// Call functions from modules
print("Math.square(5) =", Math.square(5));
print("Math.cube(3) =", Math.cube(3));
