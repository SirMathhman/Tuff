fn print_odds(n) {
  print("Odd numbers from 0 to ")
  print(n)
  for (let i in 0..n) {
    if (i % 2 == 0) {
      continue
    }
    print(i)
  }
}

fn first_negative_prefix(arr) {
  print("Finding first negative:")
  for (let i in 0..10) {
    if (i > 5) {
      break
    }
    print(i)
  }
}

print_odds(10)
print("")
first_negative_prefix([1, 2, 3, -1, 5])
