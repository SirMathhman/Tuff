{
  "hooks": {
    "Stop": [
      {
        "type": "command",
        "command": "cmd /c \"cargo +nightly llvm-cov --lcov --fail-under-lines 100 --show-missing-lines 1>&2\"; if ($LASTEXITCODE -ne 0) { exit 2 }"
      },
      {
        "type": "command",
        "command": "cmd /c \"pmd cpd --dir src --language rust --minimum-tokens 50 --ignore-literals --ignore-identifiers 1>&2\"; if ($LASTEXITCODE -ne 0) { exit 2 }"
      },
      {
        "type": "command",
        "command": "cmd /c \"powershell -NoProfile -File ./.github/hooks/check-file-length.ps1 1>&2\"; if ($LASTEXITCODE -ne 0) { exit 2 }"
      }
    ]
  }
}
