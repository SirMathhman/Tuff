{
  "hooks": {
    "Stop": [
      {
        "type": "command",
        "command": "cmd /c \"bun run test 1>&2\"; if ($LASTEXITCODE -ne 0) { exit 2 }",
        "timeout": 60
      },
      {
        "type": "command",
        "command": "cmd /c \"bun run lint 1>&2\"; if ($LASTEXITCODE -ne 0) { exit 2 }",
        "timeout": 60
      },
      {
        "type": "command",
        "command": "cmd /c \"bun run cpd 1>&2\"; if ($LASTEXITCODE -ne 0) { exit 2 }",
        "timeout": 60
      },
      {
        "type": "command",
        "command": "cmd /c \"bun test --coverage 1>&2\"; if ($LASTEXITCODE -ne 0) { exit 2 }",
        "timeout": 60
      }
    ]
  }
}
