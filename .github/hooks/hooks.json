{
  "hooks": {
    "Stop": [
      {
        "type": "command",
        "command": "powershell -File .github/hooks/scripts/run-tests.ps1",
        "timeout": 120
      },
      {
        "type": "command",
        "command": "pmd cpd --dir ./src --language cpp --minimum-tokens 50 --ignore-literals --ignore-identifiers --no-fail-on-error 1>&2"
      }
    ]
  }
}
