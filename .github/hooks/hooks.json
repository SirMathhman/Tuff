{
  "hooks": {
    "Stop": [
      {
        "type": "command",
        "command": "cmd /c \"cargo test 1>&2\"; if ($LASTEXITCODE -ne 0) { exit 2 }"
      },
      {
        "type": "command",
        "command": "cmd /c \"pmd cpd --dir src --language rust --minimum-tokens 35 --ignore-literals --ignore-identifiers 1>&2\"; if ($LASTEXITCODE -ne 0) { exit 2 }"
      },
      {
        "type": "command",
        "command": "cmd /c \"powershell -ExecutionPolicy Bypass -File .github/hooks/check-file-length.ps1\"; if ($LASTEXITCODE -ne 0) { exit 2 }"
      }
    ]
  }
}
