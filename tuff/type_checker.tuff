// ============================================================================
// TYPE INFERENCE
// ============================================================================

fn infer_type_literal(value: i32) -> Type {
    // Infer type from literal value
    // Number -> i32, String -> String, true/false -> bool, etc.
    // For now, simplified
    return type_i32();
}

fn infer_type_variable(env: TypeEnv, name: i32) -> Type {
    // Look up variable type in environment
    let ty = type_env_lookup(env, name);
    return ty;
}

fn infer_type_binary_op(op: i32, left_type: Type, right_type: Type) -> Type {
    // Infer result type from operator and operand types
    // Examples:
    //   i32 + i32 -> i32
    //   bool && bool -> bool
    //   i32 < i32 -> bool
    //   &T == &T -> bool
    
    // Arithmetic operators: +, -, *, /, %
    if op == 43 || op == 45 || op == 42 || op == 47 || op == 37 {  // +, -, *, /, %
        // Operands must be numeric (i32)
        if left_type == type_i32() && right_type == type_i32() {
            return type_i32();
        }
        return type_unknown();  // TODO: error
    }
    
    // Boolean operators: &&, ||
    if op == 38 || op == 124 {  // &&, ||
        if left_type == type_bool() && right_type == type_bool() {
            return type_bool();
        }
        return type_unknown();  // TODO: error
    }
    
    // Comparison operators: ==, !=, <, >, <=, >=
    if op == 61 || op == 33 || op == 60 || op == 62 {  // ==, !=, <, >, <=, >=
        // Operands must be same type, result is bool
        if left_type == right_type {
            return type_bool();
        }
        return type_unknown();  // TODO: error
    }
    
    return type_unknown();
}

fn infer_type_unary_op(op: i32, operand_type: Type) -> Type {
    // Infer result type from unary operator and operand type
    // Examples:
    //   -i32 -> i32
    //   !bool -> bool
    //   &T -> &T
    
    // Unary minus: operand must be numeric
    if op == 45 {  // -
        if operand_type == type_i32() {
            return type_i32();
        }
        return type_unknown();  // TODO: error
    }
    
    // Logical not: operand must be bool
    if op == 33 {  // !
        if operand_type == type_bool() {
            return type_bool();
        }
        return type_unknown();  // TODO: error
    }
    
    // Reference: & or &mut - returns reference type
    if op == 38 {  // &
        // Return reference to operand type
        return type_reference();  // TODO: construct Reference(operand_type, is_mutable)
    }
    
    return type_unknown();
}

