fn token_star() -> i32 { return 22; }
fn token_slash() -> i32 { return 23; }
fn token_percent() -> i32 { return 24; }
fn token_equal() -> i32 { return 25; }
fn token_equal_equal() -> i32 { return 26; }
fn token_not_equal() -> i32 { return 27; }
fn token_less() -> i32 { return 28; }
fn token_greater() -> i32 { return 29; }
fn token_less_equal() -> i32 { return 30; }
