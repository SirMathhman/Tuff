fn token_semicolon() -> i32 { return 48; }
fn token_arrow() -> i32 { return 49; }
fn token_pipe() -> i32 { return 50; }

// Special
fn token_eof() -> i32 { return 99; }
fn token_unknown() -> i32 { return 100; }
fn token_ident() -> i32 { return 101; }
fn token_number() -> i32 { return 102; }
fn token_string() -> i32 { return 103; }

// Character classification helpers
fn is_whitespace(code: i32) -> bool {
    return code == 32 || code == 9 || code == 10 || code == 13;
}

fn is_digit(code: i32) -> bool {
    return code >= 48 && code <= 57;
}

fn is_alpha(code: i32) -> bool {
    return (code >= 97 && code <= 122) || (code >= 65 && code <= 90);
}

fn is_alphanumeric(code: i32) -> bool {
    return is_alpha(code) || is_digit(code);
}

fn is_hex_digit(code: i32) -> bool {
    return is_digit(code) || (code >= 97 && code <= 102) || (code >= 65 && code <= 70);
}

// Simple string type - stores length and pointer to data
type String = i32;

// Keyword lookup - returns token kind if keyword, else token_ident()
fn keyword_lookup(text: String) -> i32 {
    // This is a simplified version - in real implementation would compare strings
    // For now, return token_ident to indicate it's a user-defined identifier
    return token_ident();
}

// Lexer context structure
