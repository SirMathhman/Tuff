fn type_to_c_name(ty: i32) -> i32 {
    // Convert Tuff type to C type name
    // 1 (i32) -> "int"
    // 2 (bool) -> "int"  
    // 3 (void) -> "void"
    // 4 (string) -> "char*"
    // TODO: references, generics, custom types
    
    if ty == 1 { return 0; }  // TODO: return "int"
    if ty == 2 { return 0; }  // TODO: return "int"
    if ty == 3 { return 0; }  // TODO: return "void"
    if ty == 4 { return 0; }  // TODO: return "char*"
    
    return 0;  // TODO: "void" for unknown
}

